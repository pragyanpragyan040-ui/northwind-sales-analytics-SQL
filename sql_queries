
-- NORTHWIND PROJECT SQL ANALYSIS QUERIES
******************************************************
 1. Total sum of all unit prices across order details
SELECT sum(unitPrice) 
FROM order_details;


 2. Categorizing products based on price tiers using CASE
SELECT 
    productName, 
    unitPrice,
    CASE
        WHEN unitPrice > 50 THEN 'premium'
        WHEN unitPrice > 20 THEN 'mid_range'
        ELSE 'budget'
    END AS product_category
FROM products
ORDER BY unitPrice DESC;


 3. Total revenue by product (calculated via sales order details)
SELECT 
    products.productName, 
    SUM(order_details.unitPrice) AS total_revenue
FROM products
JOIN order_details ON order_details.productID = products.productID
GROUP BY products.productName
ORDER BY total_revenue DESC;


 4. Top sales metrics by product name (alternative calculation)
SELECT 
    order_details.productID, 
    products.productName, 
    SUM(products.unitPrice) AS most_sales
FROM order_details
JOIN products ON order_details.productID = products.productID
GROUP BY order_details.productID, products.productName
ORDER BY most_sales DESC
LIMIT 10;


 5. Total revenue generated by individual customers
SELECT 
    customers.customerID, 
    customers.contactName, 
    SUM(order_details.unitPrice) AS total_revenue
FROM customers
JOIN orders ON customers.customerID = orders.customerID
JOIN order_details ON orders.orderID = order_details.orderID
GROUP BY customers.customerID, customers.contactName
ORDER BY total_revenue DESC
LIMIT 10;


 6. Total revenue broken down by customer country
SELECT 
    customers.country, 
    SUM(order_details.unitPrice) AS total_revenue
FROM customers
JOIN orders ON customers.customerID = orders.customerID
JOIN order_details ON orders.orderID = order_details.orderID
GROUP BY customers.country
ORDER BY total_revenue DESC
LIMIT 5;


 7. Ranking customers by spending (Corrected ONLY_FULL_GROUP_BY syntax)
SELECT 
    customers.contactName, 
    SUM(order_details.unitPrice) AS total,
    RANK() OVER (ORDER BY SUM(order_details.unitPrice) DESC) AS customer_rank
FROM customers
JOIN orders ON customers.customerID = orders.customerID
JOIN order_details ON orders.orderID = order_details.orderID
GROUP BY customers.contactName;


 8. Total sum of product unit prices by category name
SELECT 
    categories.categoryName, 
    SUM(products.unitPrice)
FROM categories
JOIN products ON categories.categoryID = products.categoryID
GROUP BY categories.categoryName
ORDER BY SUM(products.unitPrice);


 9. Total order sales performance per employee
SELECT 
    employees.employeeID,
    employees.employeeName, 
    SUM(order_details.unitPrice)
FROM employees
JOIN orders ON employees.employeeID = orders.employeeID
JOIN order_details ON orders.orderID = order_details.orderID
GROUP BY employees.employeeID, employees.employeeName;


 10. Summary of base unit price totals by product name
SELECT 
    productName, 
    SUM(unitPrice) AS total_revenue
FROM products
GROUP BY productName
ORDER BY total_revenue DESC;
